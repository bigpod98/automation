# Comma-separated list of id=url pairs, one entry per automation container.
# Each container is typically started with --queue <name> so it handles one queue.
# The id is used as a URL slug; the display name is derived from it automatically.
#
# Typical setup — one container per queue:
#   API_TARGETS=jivetalking=http://container1:8080,jivedrop-standalone=http://container2:8080,jivedrop-hugo=http://container3:8080,jivefire-standalone=http://container4:8080
#
# Single container running all queues (default):
#   API_TARGETS=default=http://localhost:8080
API_TARGETS=default=http://localhost:8080
